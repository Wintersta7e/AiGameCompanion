{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "../../../target/x86_64-pc-windows-msvc/release/injector",
          "sidecar": true,
          "args": ["--process", { "validator": "^[\\w.-]+\\.exe$" }, "--timeout", { "validator": "^\\d{1,3}$" }]
        }
      ]
    },
    "shell:default",
    "opener:default"
  ]
}
